{
    "name": "tunasahin/seo-images",
    "description": "Laravel SEO uyumlu resim yönetim paketi - WordPress medya kütüphanesi benzeri",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Tuna Sahin",
            "email": "tunasahin@example.com"
        }
    ],
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/tunasahincomtr/seo-images"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0",
        "illuminate/database": "^10.0",
        "illuminate/http": "^10.0",
        "intervention/image": "^3.11",
        "spatie/image-optimizer": "^1.8"
    },
    "autoload": {
        "psr-4": {
            "Tunasahin\\SeoImages\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Tunasahin\\SeoImages\\SeoImagesServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}


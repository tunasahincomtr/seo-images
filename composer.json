{
    "name": "tunasahincomtr/seo-images",
    "description": "Laravel için SEO uyumlu resim yöneticisi (AVIF, WebP, JPG dönüştürme ve SEO optimizasyonu)",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Tuna Şahin",
            "email": "alltunasahinn@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0",
        "illuminate/http": "^10.0",
        "intervention/image": "^3.11",
        "spatie/image-optimizer": "^1.8"
    },
    "autoload": {
        "psr-4": {
            "Tunasahin\\SeoImages\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Tunasahin\\SeoImages\\SeoImagesServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
